  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "compile:staging": "tsc && webpack --node-env staging",
    "compile:prod": "tsc && webpack --node-env production",
    "build:staging": "tsc && webpack --node-env staging",
    "build:prod": "tsc && webpack --node-env production",
    "build:uat": "tsc && webpack --node-env uat",
    "dev:local": "webpack --node-env local && concurrently --kill-others \"tsc -w\" \"nodemon ./build/index.js\" && cp .env.json build/",
    "dev:staging": "webpack --node-env staging && concurrently --kill-others \"tsc -w\" \"nodemon ./build/index.js\" && cp .env.json build/",
    "dev:prod": "webpack --node-env production && concurrently --kill-others \"tsc -w\" \"nodemon ./build/index.js\" && cp .env.json build/"
